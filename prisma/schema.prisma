generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(EDITOR)
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Author {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  bio       String?
  avatarUrl String?
  articles  Article[]
  createdAt DateTime  @default(now())

  @@index([slug])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  locale      String        @default("en")
  articles    Article[]
  createdAt   DateTime  @default(now())

  @@index([slug])
  @@index([locale])
}

model Opinion {
  id          Int    @id @default(autoincrement())
  pubName     String?
  content     String?
  subject     String?
  locale      String        @default("en")
  linkUrl     String?
  createdAt   DateTime  @default(now())
  
  @@index([locale])
}

model Tag {
  id       String       @id @default(cuid())
  name     String
  locale   String       @default("en")
  articles ArticleTag[]

  @@index([locale])
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String
  body        String        @db.Text
  imageUrl    String?
  locale      String        @default("en")
  status      ArticleStatus @default(DRAFT)
  featured    Boolean       @default(false)
  trending    Boolean       @default(false)
  readTime    Int           @default(5)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  authorId   String
  author     Author     @relation(fields: [authorId], references: [id])
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  tags       ArticleTag[]

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([trending])
  @@index([locale])
}

model ArticleTag {
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([articleId, tagId])
}

model Ticker {
  id        String   @id @default(cuid())
  content   String
  locale      String        @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([locale])
}
